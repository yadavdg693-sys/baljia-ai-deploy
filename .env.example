# ══════════════════════════════════════════════
# Baljia AI — Environment Variables (22 Vendors)
# ══════════════════════════════════════════════
# Copy this to .env.local and fill in your values.

# ─── Database + Auth ────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Auth ────────────────────────────────────
# JWT signing key — generate with: openssl rand -hex 32
AUTH_SECRET=your_64_char_hex_string
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── LLM Providers ──────────────────────────
# Provider priority: openai | anthropic | openrouter | moonshot | gemini (default: openai)
# Set this to control which provider is tried first across all callers.
# Optional full chain override, e.g. Anthropic/Sonnet first, OpenRouter second:
# LLM_PROVIDER_ORDER=anthropic,openrouter,openai,moonshot,gemini
PRIMARY_LLM_PROVIDER=openai

# OpenAI: GPT-5.4 (all agents), GPT-5.4-mini (classifier)
# Auth via Codex OAuth (run: npx tsx src/scripts/codex-auth.ts) or direct key:
OPENAI_API_KEY=your_openai_key

# Anthropic: Claude Sonnet 4 (agents) + Haiku 4.5 (classifier) — fallback
ANTHROPIC_API_KEY=your_anthropic_key

# Gemini 2.5 Flash — fallback
GEMINI_API_KEY=your_gemini_api_key

# OpenRouter: DeepSeek v4 Pro for full-agent fallback; Qwen for smaller modes
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_FULL_AGENT_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_REASONING_EFFORT=xhigh

# AWS Bedrock: LLM fallback (Claude/Llama/Mistral via AWS)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ─── LLM Safety (optional) ──────────────────
# LLM_TIMEOUT_MS=60000

# ─── Stripe (Billing — Baljia's own subscription revenue) ─────────
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable

# D1: Stripe Price IDs for credit packs
STRIPE_PRICE_CREDITS_30=price_xxx_starter_30
STRIPE_PRICE_CREDITS_100=price_xxx_growth_100
STRIPE_PRICE_CREDITS_300=price_xxx_scale_300

# ─── Stripe Connect (founder payment integration — Flow 2) ────────
# Used by /api/oauth/stripe/{authorize,callback} so founders can "Connect with
# Stripe" instead of pasting an API key. Setup (no Partner approval needed):
#   1. Enable Connect in Baljia's Stripe dashboard (Settings → Connect)
#   2. Register a platform under Connect Settings → choose Standard accounts
#   3. Copy the ca_xxx client_id into STRIPE_CONNECT_CLIENT_ID
# STRIPE_PLATFORM_SECRET_KEY is Baljia's own sk_test_/sk_live_ — used by the
# OAuth code-exchange call. Usually identical to STRIPE_SECRET_KEY above; set
# separately if you want to silo billing keys from Connect keys.
STRIPE_CONNECT_CLIENT_ID=ca_xxx
STRIPE_PLATFORM_SECRET_KEY=sk_test_xxx

# ─── Upstash Redis (Queue + Rate Limiting) ──
REDIS_URL=redis://default:password@host:6379
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
DISABLE_CREDIT_DAILY_CAPS=false

# ─── Neon (Founder company databases) ───────
NEON_API_KEY=your_neon_api_key

# ─── Cloudflare R2 (Object storage) ─────────
# S3-compatible storage for ad creatives, screenshots, generated media.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=baljia-assets
R2_PUBLIC_URL=https://assets.baljia.app

# ─── Cloudflare DNS + Email Routing ─────────
# Used for: {company}.baljia.app subdomains + {company}@baljia.app emails
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID_APP=your_baljia_app_zone_id

# ─── Postmark (Account-level for sender signatures) ──
# Account token (different from server token) — for creating sender signatures
POSTMARK_ACCOUNT_TOKEN=your_postmark_account_token
# Inbound webhook address (where forwarded emails go for processing)
POSTMARK_INBOUND_ADDRESS=inbound@inbound.baljia.app

# ─── HeyGen (primary ad-video generation) ───
# Prompt-to-video ad creative via HeyGen Video Agent.
HEYGEN_API_KEY=your_heygen_api_key

# Promo video voiceover
DEEPGRAM_API_KEY=your_deepgram_api_key
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en
# Local Supertonic voiceover (pip install supertonic; first run downloads model assets)
# PROMO_VIDEO_TTS_PROVIDER=supertonic
# SUPERTONIC_PYTHON_COMMAND=python
# SUPERTONIC_VOICE=F3
# SUPERTONIC_LANG=en
# SUPERTONIC_STEPS=5
# SUPERTONIC_SPEED=1.05
# Founder avatar voice uses HeyGen Starfish voice IDs.
# HEYGEN_FOUNDER_VOICE_ID=your_founder_voice_id
# HEYGEN_FOUNDER_VOICE_SPEED=1

# ─── Fal.ai (optional AI media fallback) ─────
# Flux images, Kling/Minimax video, F5-TTS, image upscaling
FAL_KEY=your_fal_api_key

# ─── Tavily (Research agent — web search) ───
TAVILY_API_KEY=your_tavily_api_key

# ─── Hunter.io (Cold outreach) ──────────────
HUNTER_API_KEY=your_hunter_api_key

# ─── Postmark (Transactional email) ─────────
POSTMARK_SERVER_TOKEN=your_postmark_server_token

# ─── Twitter/X API (Social media agent) ─────
# OAuth 1.0a — get keys from https://developer.x.com
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# ─── Meta Marketing API (Paid ads agent) ────
META_ADS_ACCESS_TOKEN=your_meta_access_token
META_ADS_ACCOUNT_ID=act_your_ad_account_id

# ─── Meta Pixel/CAPI (Conversion tracking) ──
META_PIXEL_ID=your_pixel_id
META_CAPI_ACCESS_TOKEN=your_capi_access_token

# ─── Browserbase (Cloud browser automation) ─
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_browserbase_project_id

# ─── GitHub (Engineering agent) ─────────────
GITHUB_TOKEN=your_github_pat
GITHUB_ORG=baljia-ai

# ─── Render (Engineering agent — deploy) ────
RENDER_API_KEY=your_render_api_key
RENDER_OWNER_ID=your_render_owner_id

# ─── Late.dev (Multi-platform social) ───────
# Unified API for posting to Twitter, LinkedIn, Instagram, Facebook, Threads
LATEDEV_API_KEY=your_latedev_api_key

# ─── Slack (Notifications) ──────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_DEFAULT_CHANNEL=#baljia-alerts

# ─── ScreenshotOne (Website screenshots) ────
SCREENSHOTONE_API_KEY=your_screenshotone_api_key

# ─── Expo EAS (Mobile builds) ───────────────
# Build and distribute React Native apps to App Store / Play Store
EXPO_TOKEN=your_expo_access_token

# ─── IPinfo (IP geolocation) ────────────────
IPINFO_TOKEN=your_ipinfo_token

# ─── Sentry (Error monitoring) ──────────────
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=baljia-ai
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ─── Domain ─────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=baljia.app

# ─── RBAC / Admin Access ────────────────────
# ADMIN_EMAILS=admin@example.com,ops@example.com

# ─── Logging ─────────────────────────────────
# LOG_LEVEL=info

# ─── Cron Auth ───────────────────────────────
# D2: Secret key for authenticating scheduled cron job endpoints
CRON_SECRET=your_cron_secret_min_32_chars
